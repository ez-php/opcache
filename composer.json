{
    "name": "ez-php/opcache",
    "version": "1.5.0",
    "description": "OPcache preload script generator for the ez-php framework — scans class paths and writes a ready-to-use preload.php",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "opcache",
        "preloading",
        "performance",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/opcache",
    "support": {
        "issues": "https://github.com/ez-php/opcache/issues",
        "source": "https://github.com/ez-php/opcache"
    },
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\OPCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
